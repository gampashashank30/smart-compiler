# ─────────────────────────────────────────────────────────────────
# .dockerignore — Exclude files from Docker build context
#
# IMPORTANT: Only exclude files that are NOT needed by any Docker stage.
# The builder stage (Stage 1) needs: src/, vite.config.js, eslint.config.js,
# index.html, app.html, login.html, public/, package*.json
# The runtime stage (Stage 2) needs: server/, and copies dist/ from builder.
# ─────────────────────────────────────────────────────────────────

# Git history — never needed in Docker
.git
.gitignore

# Environment files — secrets come from runtime env vars
.env
.env.*
!.env.example

# Scratch and test files — not needed in any stage
scratch/
test_*.mjs
test_*.js
*.test.js
*.spec.js
test_detection.mjs

# Database migration scripts — sensitive schema, not needed in container
streak_migration.sql

# Editor and OS files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln

# Node modules — reinstalled inside container for correct platform (Linux)
node_modules/
server/node_modules/

# Built output at root level (if it exists locally — rebuilt inside container)
dist/
dist-ssr/

# Logs
*.log
logs/

# Agent scratch directories
.agents/

# NOTE: vite.config.js, eslint.config.js, src/, public/ are intentionally NOT
# excluded — Stage 1 (builder) needs them to run `npm run build`.
# They never reach the runtime image thanks to the multi-stage build.
