# ─────────────────────────────────────────────────────────────────────────────
# smart-compiler — Environment Variables Template
#
# Copy this file to .env and fill in your own keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API keys (https://console.groq.com/keys)
# Key 2 and 3 are optional fallbacks used when key 1 hits rate limits.
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here

# Supabase (https://supabase.com/dashboard/project/<your-project>/settings/api)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ISSUE 9 FIX: Standardized to SUPABASE_SERVICE_KEY (was SUPABASE_SECRET_KEY before)
# This is the service role key — bypasses RLS. Never expose to frontend.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ISSUE 5 FIX: Admin emails moved OUT of source code — set here as a comma-separated list.
# These users get access to the Admin dashboard and full /api/health diagnostics.
# Example: ADMIN_EMAILS=you@example.com,colleague@example.com
ADMIN_EMAILS=your_admin_email@example.com
